    "import numpy as np\n",
    "point_a_np=np.array([1,1,1])\n",
    "point_b_np = np.array([4, 5, 6]) \n",
    "distance_numpy = np.sum(np.abs(point_a_np - point_b_np))\n",
    "print(f\"Manhattan distance (NumPy): {distance_numpy}\")\n"
   ]
